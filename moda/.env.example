SMTP_LISTEN_HOST=0.0.0.0
SMTP_LISTEN_PORT=2525

RELAY_HOST=mailpit
RELAY_PORT=1025

HEALTH_HOST=0.0.0.0
HEALTH_PORT=8080

WEB_UI_HOST=0.0.0.0
WEB_UI_PORT=8081

SIMULATE_ANALYZER=true
# Reserved for a future remote-analyzer adapter; the current gateway invokes MODA directly.
ANALYZER_URL=http://analyzer:8000/analyze
SKIP_YARA=false

MAX_MESSAGE_BYTES=26214400
MAX_ATTACHMENT_BYTES=20971520
MAX_ATTACHMENTS=20
ANALYZER_TIMEOUT_SECONDS=30

ACCEPTED_RECIPIENT_DOMAINS=example.test
QUARANTINE_PATH=/quarantine

# Optional report chatbot. Choose "openai" or "gemini" and set only that provider's key.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash-lite
LLM_TIMEOUT_SECONDS=90
LLM_MAX_CONTEXT_CHARS=60000
LLM_MAX_OUTPUT_TOKENS=1600
LLM_MAX_RETRIES=3
